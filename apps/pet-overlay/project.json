{
    "name": "pet-overlay",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "prefix": "app",
    "sourceRoot": "apps/pet-overlay/src",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@angular/build:application",
            "outputs": ["{options.outputPath}"],
            "defaultConfiguration": "production",
            "options": {
                "outputPath": "dist/apps/pet-overlay",
                "index": "apps/pet-overlay/src/index.html",
                "browser": "apps/pet-overlay/src/main.ts",
                "tsConfig": "apps/pet-overlay/tsconfig.app.json",
                "inlineStyleLanguage": "scss",
                "baseHref": "./",
                "assets": [
                    {
                        "glob": "**/*",
                        "input": "apps/pet-overlay/public"
                    }
                ],
                "styles": ["apps/pet-overlay/src/styles.scss"],
                "stylePreprocessorOptions": {
                    "includePaths": ["apps/pet-overlay/src/styles"]
                }
            },
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "500kb",
                            "maximumError": "1mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "4kb",
                            "maximumError": "8kb"
                        }
                    ],
                    "outputHashing": "all"
                },
                "development": {
                    "optimization": false,
                    "extractLicenses": false,
                    "sourceMap": true
                }
            }
        },
        "serve": {
            "continuous": true,
            "executor": "@angular/build:dev-server",
            "defaultConfiguration": "development",
            "configurations": {
                "production": {
                    "buildTarget": "pet-overlay:build:production"
                },
                "development": {
                    "buildTarget": "pet-overlay:build:development"
                }
            }
        },
        "lint": {
            "inputs": [
                "default",
                "^default",
                "{workspaceRoot}/.eslintrc.json",
                "{workspaceRoot}/.eslintignore",
                "{workspaceRoot}/eslint.config.mjs",
                "{workspaceRoot}/tools/eslint-rules/**/*",
                {
                    "externalDependencies": ["eslint"]
                }
            ]
        },
        "serve-static": {
            "continuous": true,
            "executor": "@nx/web:file-server",
            "options": {
                "buildTarget": "pet-overlay:build",
                "staticFilePath": "dist/apps/pet-overlay/browser",
                "spa": true
            }
        }
    }
}
